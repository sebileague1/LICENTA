import paramiko
import time

# =====================================================================
# CONFIGURARE RETEA
# =====================================================================
VALID_TRIGGER_IPS = [
    "172.17.0.1",       # Gateway bridge docker0
    "172.17.0.2",       # Metasploitable2 direct
    "172.19.0.1",       # Gateway bridge retea Greenbone
    "192.168.128.181",  # Ubuntu host fizic
    "172.19.0.100",     # Metasploitable2 IP static
]

SSH_HOST    = "172.19.0.100"
SSH_PORT    = 22
TARGET_USER = "msfadmin"
TARGET_PASS = "msfadmin"

# =====================================================================
# FUNCTII SOAR
# =====================================================================
def log_soar(msg):
    print(f"[SOAR] {msg}", flush=True)

def verify_ftp_stopped(client):
    """Verifica daca portul 21 mai este deschis."""
    stdin, stdout, stderr = client.exec_command("netstat -tuln | grep ':21 '")
    output = stdout.read().decode('utf-8')
    return output.strip() == ""

def execute_ftp_mitigation(target_ip):
    log_soar(f"🛡️ INITIERE: Oprire FTP pe {target_ip}")

    try:
        client = paramiko.SSHClient()
        client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        
        client.connect(
            hostname=SSH_HOST,
            port=SSH_PORT,
            username=TARGET_USER,
            password=TARGET_PASS,
            timeout=10,
            look_for_keys=False,
            allow_agent=False,
            disabled_algorithms={
                'pubkeys': ['rsa-sha2-256', 'rsa-sha2-512'],
                'keys': ['rsa-sha2-256', 'rsa-sha2-512']
            }
        )

        # Pre-check
        if verify_ftp_stopped(client):
            log_soar(f"ℹ️ Portul 21 deja inactiv pe {target_ip}")
            client.close()
            return "✅ **STATUT:** Portul 21 (FTP) deja inactiv."

        log_soar("⚙️ Executie comenzi mitigare...")

        # Comenzi agresive de oprire FTP
        commands = [
            f"echo '{TARGET_PASS}' | sudo -S service vsftpd stop 2>/dev/null",
            f"echo '{TARGET_PASS}' | sudo -S service proftpd stop 2>/dev/null",
            f"echo '{TARGET_PASS}' | sudo -S killall -9 vsftpd 2>/dev/null",
            f"echo '{TARGET_PASS}' | sudo -S killall -9 proftpd 2>/dev/null",
            f"echo '{TARGET_PASS}' | sudo -S killall -9 inetd 2>/dev/null",
            f"echo '{TARGET_PASS}' | sudo -S fuser -k -9 21/tcp 2>/dev/null",
            f"echo '{TARGET_PASS}' | sudo -S bash -c 'lsof -t -i:21 | xargs -r kill -9' 2>/dev/null"
        ]

        for cmd in commands:
            try:
                stdin, stdout, stderr = client.exec_command(cmd, timeout=5)
                stdout.channel.recv_exit_status()  # Wait for completion
                time.sleep(0.3)
            except Exception as cmd_err:
                log_soar(f"⚠️ Comanda esuata (continuu): {cmd_err}")

        time.sleep(2)  # Asteptare stabilizare

        # Post-check
        if verify_ftp_stopped(client):
            log_soar(f"✅ CONFIRMAT: Port 21 oprit pe {target_ip}")
            client.close()
            return (
                "🛡️ **SOAR SUCCES:**\n"
                f"✅ Portul 21 (FTP) oprit pe `{target_ip}`\n"
                f"🔒 Servicii terminate: vsftpd, proftpd, inetd\n"
                f"⏱️ Durata operație: ~3 secunde"
            )
        else:
            client.close()
            log_soar(f"❌ Port 21 refuza inchidere pe {target_ip}")
            return "❌ **SOAR ESEC:** Portul 21 refuza inchidere. Interventie manuala."

    except Exception as e:
        msg = f"⚠️ **SOAR EROARE:** {type(e).__name__}: {str(e)}"
        log_soar(msg)
        return msg

def trigger_remediation(ip_sursa_alerta, vuln_name):
    """Entry point SOAR - evalueaza si executa remedieri."""
    vuln_lower = vuln_name.lower()
    
    log_soar(f"🔍 Evaluare: IP={ip_sursa_alerta} | Vuln={vuln_name[:80]}")

    # Verificare IP in whitelist
    if ip_sursa_alerta not in VALID_TRIGGER_IPS:
        log_soar(f"⏭️ IP {ip_sursa_alerta} NU e in VALID_TRIGGER_IPS - Ignorat")
        return None

    # ========== PATTERN MATCHING FLEXIBLE ==========
    # FTP Vulnerabilities - orice vulnerabilitate FTP activeaza remedierea
    ftp_keywords = [
        "ftp",
        "vsftpd",
        "proftpd",
        "file transfer protocol"
    ]
    
    # Check daca e vulnerabilitate FTP
    is_ftp_vuln = any(keyword in vuln_lower for keyword in ftp_keywords)
    
    # Exceptii - FTP-uri pe care NU vrem sa le remedieze automat
    ftp_exceptions = [
        "ftp server detection",  # Doar detectie, nu vuln
        "ftp bounce",            # Alt tip de atac
    ]
    
    is_exception = any(exception in vuln_lower for exception in ftp_exceptions)
    
    if is_ftp_vuln and not is_exception:
        log_soar(f"🎯 TINTA CONFIRMATA: Vulnerabilitate FTP pe {ip_sursa_alerta}")
        log_soar(f"📝 Pattern match: {vuln_name}")
        return execute_ftp_mitigation(ip_sursa_alerta)
    
    # SSH Vulnerabilities - doar logging, fara remediere (anti-lockout)
    if "ssh" in vuln_lower:
        log_soar("🔒 Politica SSH: Remediere DEZACTIVATA (Anti-Lockout)")
        return "🛡️ **POLITICA:** SSH remediation disabled (Anti-Lockout)."
    
    # Alte vulnerabilitati - momentan fara actiune
    log_soar(f"ℹ️ Niciun playbook disponibil pentru: {vuln_name[:60]}")
    return None
